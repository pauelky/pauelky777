TG_API_ID=123456
TG_API_HASH=your_telegram_api_hash
SOO_BOT_TOKEN=your_bot_token

# Comma-separated admin user IDs
ADMIN_IDS=123456789

# Optional: explicit bot username fallback (without @)
BOT_USERNAME=your_bot_username

# Optional critical alerts target chat/user (admin DM or "Избранное")
ALERT_CHAT_ID=123456789

# Optional timezone for reports and human-readable timestamps
TIMEZONE=Europe/Moscow

# Optional filter to restrict tracked chats at runtime
# ALLOWED_CHAT_IDS=-100123,-100456

# --- Mini App / FastAPI ---
AI_APP_HOST=0.0.0.0
AI_APP_PORT=8000

# IMPORTANT: set real public HTTPS URL for Telegram Mini App
# Example: https://savedbot.example.com/miniapp
AI_WEBAPP_URL=https://savedbot.example.com/miniapp

# Optional fallback if AI_WEBAPP_URL is empty:
# PUBLIC_BASE_URL=https://numinously-sportful-todd.ngrok-free.dev

# Optional AI/API tuning
AI_MAX_RESULT_ROWS=40
AI_MAX_ANSWER_CHARS=700
AI_MAX_QUESTION_CHARS=700
AI_ARCHIVE_PAGE_SIZE=40

# Optional OpenRouter integration for AI endpoint
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_MODEL=baidu/cobuddy:free

# Storage base (docker-compose overrides to /data)
BASE_DIR=/data
