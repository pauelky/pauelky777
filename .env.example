TG_API_ID=123456
TG_API_HASH=your_telegram_api_hash
SOO_BOT_TOKEN=your_bot_token

# Comma-separated admin user IDs
ADMIN_IDS=123456789

# Optional: explicit bot username fallback (without @)
BOT_USERNAME=your_bot_username

# Optional critical alerts target chat/user (admin DM or "Избранное")
ALERT_CHAT_ID=123456789

# Optional timezone for reports and human-readable timestamps
TIMEZONE=Europe/Moscow

# Storage base (docker-compose overrides to /data)
BASE_DIR=/data
